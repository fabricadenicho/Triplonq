//@version=5
strategy("S1 — ROT-LONG + Acima 4H Open", overlay=true,
         initial_capital=10000, default_qty_type=strategy.fixed, default_qty_value=1,
         commission_type=strategy.commission.percent, commission_value=0.01,
         max_labels_count=500, max_bars_back=500, max_lines_count=500)

// ── Inputs ────────────────────────────────────────────────────────────────────
i_rsi      = input.int(21,  "RSI Period",           minval=5)
i_adx      = input.int(17,  "ADX Period",           minval=5)
i_bb       = input.int(20,  "BB Period",            minval=5)
i_cl       = input.symbol("CL1!",            "Simbolo CL")
i_es       = input.symbol("ES1!",            "Simbolo ES")
i_btc      = input.symbol("BINANCE:BTCUSDT", "Simbolo BTC")
i_stop_atr = input.float(1.5, "Stop (x ATR14)",  minval=0.5, step=0.5)
i_tgt_atr  = input.float(3.0, "Target (x ATR14)", minval=1.0, step=0.5)

// ── 4H Open Line ─────────────────────────────────────────────────────────────
i_show_4h  = input.bool(true,  "Mostrar 4H Open Line",   group="4H Open Line")
i_col_4h   = input.color(color.new(color.yellow, 20), "Cor 4H Open", group="4H Open Line")

// ── MNQ ──────────────────────────────────────────────────────────────────────
rsi_mnq         = ta.rsi(close, i_rsi)
[_, _, adx_mnq] = ta.dmi(i_adx, i_adx)
above50_mnq     = close > ta.sma(close, 50) ? 1 : 0
ret1_mnq        = nz(close[1], close) != 0 ? (close - nz(close[1], close)) / nz(close[1], close) : 0.0
atr14           = ta.atr(14)

// ── CL ────────────────────────────────────────────────────────────────────────
cl_c         = request.security(i_cl, timeframe.period, close)
rsi_cl       = ta.rsi(cl_c, i_rsi)
cl_sma_bb    = ta.sma(cl_c, i_bb)
cl_std_bb    = ta.stdev(cl_c, i_bb)
bb_wid_cl    = cl_sma_bb != 0 ? cl_std_bb * 2 / cl_sma_bb * 100 : 0.0
above50_cl   = request.security(i_cl, timeframe.period, close > ta.sma(close, 50) ? 1 : 0)
cl_dopen     = request.security(i_cl, "D", open,    lookahead=barmerge.lookahead_on)
cl_dopen_ant = request.security(i_cl, "D", open[1], lookahead=barmerge.lookahead_on)

// ── ES ────────────────────────────────────────────────────────────────────────
es_c       = request.security(i_es, timeframe.period, close)
above50_es = request.security(i_es, timeframe.period, close > ta.sma(close, 50) ? 1 : 0)
ret1_es    = nz(es_c[1], es_c) != 0 ? (es_c - nz(es_c[1], es_c)) / nz(es_c[1], es_c) : 0.0

// ── BTC ───────────────────────────────────────────────────────────────────────
above50_btc = request.security(i_btc, timeframe.period, close > ta.sma(close, 50) ? 1 : 0)

// ── Divergencia e Rotacao ─────────────────────────────────────────────────────
div_cl          = rsi_mnq - rsi_cl
div_delta_2h    = div_cl - nz(div_cl[2])
div_sinal_mudou = (div_cl > 0 and nz(div_cl[1]) <= 0) or (div_cl < 0 and nz(div_cl[1]) >= 0)
rsi_mnq_d2      = rsi_mnq - nz(rsi_mnq[2])
rsi_cl_d2       = rsi_cl  - nz(rsi_cl[2])
rot_ativa       = rsi_mnq_d2 > 2.0 and rsi_cl_d2 < -2.0

// ── 9 Condicoes ponderadas ────────────────────────────────────────────────────
c1 = div_sinal_mudou
c2 = div_delta_2h > 5.0
c3 = rot_ativa
c4 = (ret1_mnq > 0 and ret1_es > 0) or (ret1_mnq < 0 and ret1_es < 0)
c5 = bb_wid_cl > 1.5
c6 = cl_dopen > cl_dopen_ant
c7 = adx_mnq >= 12 and adx_mnq <= 20
c8 = (above50_mnq + above50_cl + above50_es + above50_btc) >= 2
c9 = rsi_mnq > 55 or rsi_mnq < 45

sc        = (c1?3.0:0.0)+(c2?2.5:0.0)+(c3?2.5:0.0)+(c4?2.0:0.0)+(c5?1.5:0.0)+(c6?1.5:0.0)+(c7?1.5:0.0)+(c8?1.5:0.0)+(c9?1.0:0.0)
score_pct = sc / 17.0 * 100
rotacao   = score_pct >= 60.0
rot_new   = rotacao and not nz(rotacao[1], false)

// ── Gate 2: Direcao LONG (div_cl > 0) ────────────────────────────────────────
dir_long = div_cl > 0

// ── Gate 3: Acima da abertura 4H ─────────────────────────────────────────────
open_4h    = request.security(syminfo.tickerid, "240", open, lookahead=barmerge.lookahead_on)
above_4h   = close > open_4h
_4h_chg    = timeframe.change("240")

// Linha 4H Open (limita ao periodo de 4h)
var line _4h_ln = na
if i_show_4h
    if _4h_chg
        if not na(_4h_ln)
            line.set_x2(_4h_ln, bar_index - 1)
        _4h_ln := line.new(bar_index, open_4h, bar_index, open_4h, color=i_col_4h, width=1, style=line.style_dashed)
    else if not na(_4h_ln)
        line.set_x2(_4h_ln, bar_index)

// ── Sinal S1: todos os 3 gates + nova rotacao ─────────────────────────────────
// (Gate ML = proxy via score >= 60 que ja inclui features similares ao modelo XGBoost)
s1_long = rot_new and dir_long and above_4h

// ── Stop e Target (ATR) ───────────────────────────────────────────────────────
var float _stop  = na
var float _limit = na

if s1_long
    _stop  := close - atr14 * i_stop_atr
    _limit := close + atr14 * i_tgt_atr
    strategy.entry("S1-LONG", strategy.long)

if strategy.position_size > 0
    strategy.exit("S1-LONG-X", "S1-LONG", stop=_stop, limit=_limit)

// ── Plots ─────────────────────────────────────────────────────────────────────
// Fundo: score >= 60 + direcao
bgcolor(rotacao and dir_long     ? color.new(color.green, 94) : na, title="Score LONG ativo")
bgcolor(rotacao and not dir_long ? color.new(color.red,   97) : na, title="Score SHORT ativo")
// Destaque quando close cruzou para acima do 4H open
bgcolor(rotacao and dir_long and above_4h and not nz(above_4h[1], false) ? color.new(color.lime, 78) : na, title="Cruz acima 4H + LONG")

plotshape(s1_long, title="S1 LONG", style=shape.labelup, location=location.belowbar, color=color.new(color.lime, 0), text="S1", textcolor=color.black, size=size.normal)

// Score bar (plot no painel overlay — valor informativo)
plot(score_pct, title="Score Rotacao %", color=color.new(color.yellow, 60), linewidth=1, display=display.none)
plot(div_cl,    title="DIV CL",          color=color.new(color.teal,   60), linewidth=1, display=display.none)

// ── Tabela de status ──────────────────────────────────────────────────────────
var table tbl = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black, 65), border_color=color.new(color.gray, 60), border_width=1)

if barstate.islast
    cg   = color.new(color.lime,   0)
    cr   = color.new(color.red,    0)
    cy   = color.new(color.yellow, 0)
    csil = color.new(color.silver, 0)
    cbg  = color.new(color.black,  60)
    cok  = color.new(color.green,  70)
    cno  = color.new(color.black,  80)

    sc_col = score_pct >= 60 ? cg : score_pct >= 40 ? cy : csil
    g1_bg  = rotacao   ? cok : cno
    g2_bg  = dir_long  ? cok : cno
    g3_bg  = above_4h  ? cok : cno
    s1_col = s1_long   ? cg  : csil
    s1_bg  = s1_long   ? color.new(color.green, 55) : cbg

    table.cell(tbl, 0, 0, "GATE",            text_color=csil,  bgcolor=color.new(color.navy, 40), text_size=size.tiny)
    table.cell(tbl, 1, 0, "STATUS",          text_color=csil,  bgcolor=color.new(color.navy, 40), text_size=size.tiny)
    table.cell(tbl, 0, 1, "Score >= 60%",    text_color=rotacao   ? cg : csil, bgcolor=g1_bg, text_size=size.tiny)
    table.cell(tbl, 1, 1, str.tostring(score_pct, "#.#") + "%", text_color=rotacao ? cg : csil, bgcolor=g1_bg, text_size=size.tiny)
    table.cell(tbl, 0, 2, "DIV CL > 0",     text_color=dir_long  ? cg : csil, bgcolor=g2_bg, text_size=size.tiny)
    table.cell(tbl, 1, 2, str.tostring(div_cl, "#.#"), text_color=div_cl > 0 ? cg : cr, bgcolor=g2_bg, text_size=size.tiny)
    table.cell(tbl, 0, 3, "Close > 4H open",text_color=above_4h  ? cg : csil, bgcolor=g3_bg, text_size=size.tiny)
    table.cell(tbl, 1, 3, above_4h ? "SIM" : "NAO", text_color=above_4h ? cg : cr, bgcolor=g3_bg, text_size=size.tiny)
    table.cell(tbl, 0, 4, "4H Open",         text_color=csil,  bgcolor=cbg, text_size=size.tiny)
    table.cell(tbl, 1, 4, str.tostring(open_4h, "#.##"), text_color=csil, bgcolor=cbg, text_size=size.tiny)
    table.cell(tbl, 0, 5, "RSI MNQ / CL",   text_color=csil,  bgcolor=cbg, text_size=size.tiny)
    table.cell(tbl, 1, 5, str.tostring(rsi_mnq, "#.#") + " / " + str.tostring(rsi_cl, "#.#"), text_color=csil, bgcolor=cbg, text_size=size.tiny)
    table.cell(tbl, 0, 6, "S1 SINAL",        text_color=s1_col, bgcolor=s1_bg, text_size=size.tiny)
    table.cell(tbl, 1, 6, s1_long ? "LONG" : "AGUARDAR", text_color=s1_col, bgcolor=s1_bg, text_size=size.tiny)

// ── Alertas ───────────────────────────────────────────────────────────────────
alertcondition(s1_long, title="S1 LONG MNQ", message="S1 LONG MNQ — Score: {{plot_0}}% | DIV: {{plot_1}} | Acima 4H open")
alertcondition(rot_new and dir_long and not above_4h, title="S1 Parcial (sem gate 4H)", message="S1 PARCIAL: Rotacao LONG sem confirmacao 4H open — aguardar cruzamento")
