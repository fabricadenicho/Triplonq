//@version=5
indicator("Reversao a Media 15M/5M", overlay=true, max_bars_back=500)

// ── Parametros ────────────────────────────────────────────────────────────────
i_rsi_len   = input.int(14,   "RSI Period")
i_bb_len    = input.int(20,   "BB Period")
i_bb_dev    = input.float(2.0,"BB Desvio", step=0.1)
i_rsi_ob    = input.int(65,   "RSI Overbought", minval=55, maxval=80)
i_rsi_os    = input.int(35,   "RSI Oversold",   minval=20, maxval=45)
i_cl        = input.symbol("CL1!", "Simbolo CL")
i_show_bb   = input.bool(true, "Mostrar BB", group="Visuais")
i_show_bg   = input.bool(true, "Fundo extremos", group="Visuais")

// ── Indicadores 15M (nativo) ──────────────────────────────────────────────────
rsi15   = ta.rsi(close, i_rsi_len)
bb_mid  = ta.sma(close, i_bb_len)
bb_std  = ta.stdev(close, i_bb_len)
bb_upp  = bb_mid + bb_std * i_bb_dev
bb_low  = bb_mid - bb_std * i_bb_dev
bb_pctb = (close - bb_low) / (bb_upp - bb_low)
bb_wid  = (bb_upp - bb_low) / bb_mid * 100

// Distancias das medias
ema9    = ta.ema(close, 9)
ema20   = ta.ema(close, 20)

// CL RSI no 15M (divergencia foi top feature no backtest)
cl_c15  = request.security(i_cl, timeframe.period, close, lookahead=barmerge.lookahead_off)
rsi_cl15 = ta.rsi(cl_c15, i_rsi_len)
div_cl15 = rsi15 - rsi_cl15

// ── Indicadores 5M via security() ────────────────────────────────────────────
rsi5m       = request.security(syminfo.tickerid, "5", ta.rsi(close, i_rsi_len),    lookahead=barmerge.lookahead_off)
bb_pctb_5m  = request.security(syminfo.tickerid, "5", (close - (ta.sma(close, i_bb_len) - ta.stdev(close, i_bb_len) * i_bb_dev)) / (ta.stdev(close, i_bb_len) * i_bb_dev * 2), lookahead=barmerge.lookahead_off)

// ── Setups 15M ────────────────────────────────────────────────────────────────
// LONG reversion: RSI oversold + abaixo da BB inferior
// (backtest: AUC=0.5649 no 15m)
long_rev15  = rsi15 < i_rsi_os and close < bb_low

// SHORT reversion: RSI overbought + acima da BB superior
// (backtest: AUC=0.6504 no 15m — melhor sinal encontrado)
short_rev15 = rsi15 > i_rsi_ob and close > bb_upp

// Divergencia CL ajuda (top feature): SHORT mais forte quando CL nao esta overbought
short_rev15_forte = short_rev15 and div_cl15 < 5.0
long_rev15_forte  = long_rev15  and div_cl15 > -5.0

// ── Contexto 5M ───────────────────────────────────────────────────────────────
// No 5m, o setup de "reversao" e na verdade CONTINUACAO (AUC invertido = 0.71)
// 5m abaixo da BB = momentum DOWN ainda ativo = cuidado pro LONG
// 5m acima da BB = momentum UP ainda ativo = cuidado pro SHORT (ou entrada mais forte)
momentum_short_5m = rsi5m > i_rsi_ob and bb_pctb_5m > 1.0
momentum_down_5m  = rsi5m < i_rsi_os and bb_pctb_5m < 0.0

// SHORT ideal: 15m overbought + 5m tambem overbought = momentum forte, boa reversao
short_confluencia = short_rev15 and momentum_short_5m

// LONG: cuidado se 5m ainda em momentum de queda
long_sem_5m_down  = long_rev15 and not momentum_down_5m

// ── Visuais ───────────────────────────────────────────────────────────────────
bb_upp_plot = plot(i_show_bb ? bb_upp : na, "BB Sup", color=color.new(color.gray, 60), linewidth=1)
bb_low_plot = plot(i_show_bb ? bb_low : na, "BB Inf", color=color.new(color.gray, 60), linewidth=1)
plot(i_show_bb ? bb_mid : na, "BB Mid", color=color.new(color.gray, 75), linewidth=1, style=plot.style_circles)
fill(bb_upp_plot, bb_low_plot, color=color.new(color.gray, 95))

plot(ema9,  "EMA9",  color=color.new(color.blue,   30), linewidth=1)
plot(ema20, "EMA20", color=color.new(color.orange, 30), linewidth=1)

// Fundo quando em extremo
bg_col = short_rev15 ? color.new(color.red, 88) : long_rev15 ? color.new(color.green, 88) : na
bgcolor(i_show_bg ? bg_col : na, title="Extremo RSI+BB")

// Sinais de entrada
plotshape(long_rev15_forte,       style=shape.triangleup,   location=location.belowbar, color=color.lime,            size=size.small,  title="LONG Rev 15M")
plotshape(short_rev15_forte,      style=shape.triangledown, location=location.abovebar, color=color.red,             size=size.small,  title="SHORT Rev 15M")
plotshape(short_confluencia,      style=shape.triangledown, location=location.abovebar, color=color.new(color.red,0),size=size.normal, title="SHORT 15M+5M")
plotshape(long_sem_5m_down,       style=shape.triangleup,   location=location.belowbar, color=color.new(color.lime,0),size=size.normal, title="LONG 15M s/ down 5M")

// ── Tabela de status ──────────────────────────────────────────────────────────
var table tbl = table.new(position.top_right, 2, 8, border_width=1, border_color=color.gray, bgcolor=color.new(color.black, 70))

if barstate.islast
    csil = color.new(color.silver, 0)
    chdr = color.new(color.navy, 50)
    cok  = color.new(color.green, 60)
    cno  = color.new(color.gray, 80)
    cred = color.new(color.red, 60)

    table.cell(tbl, 0, 0, "REVERSAO",      text_color=csil, bgcolor=chdr, text_size=size.tiny)
    table.cell(tbl, 1, 0, "STATUS",        text_color=csil, bgcolor=chdr, text_size=size.tiny)

    rsi15_str   = str.tostring(math.round(rsi15, 1))
    pctb_str    = str.tostring(math.round(bb_pctb * 100, 1)) + "%"
    rsi5m_str   = str.tostring(math.round(rsi5m, 1))
    pctb5_str   = str.tostring(math.round(bb_pctb_5m * 100, 1)) + "%"
    divcl_str   = str.tostring(math.round(div_cl15, 1))

    s_rev15  = short_rev15 ? "OB " + rsi15_str : long_rev15 ? "OS " + rsi15_str : "neutro"
    s_rev15c = short_rev15 ? cred : long_rev15 ? cok : cno
    s_rev5m  = momentum_short_5m ? "OB " + rsi5m_str : momentum_down_5m ? "OS " + rsi5m_str : "neutro"
    s_rev5mc = momentum_short_5m ? cred : momentum_down_5m ? cok : cno
    s_short  = short_confluencia ? "FORTE" : short_rev15 ? "simples" : "off"
    s_shortc = short_confluencia ? cred : short_rev15 ? color.new(color.red, 75) : cno
    s_long   = long_sem_5m_down ? "OK" : long_rev15 ? "5m down" : "off"
    s_longc  = long_sem_5m_down ? cok : long_rev15 ? color.new(color.orange, 60) : cno

    table.cell(tbl, 0, 1, "RSI 15m",   text_color=csil, bgcolor=cno, text_size=size.tiny)
    table.cell(tbl, 1, 1, rsi15_str,   text_color=csil, bgcolor=cno, text_size=size.tiny)
    table.cell(tbl, 0, 2, "BB %B 15m", text_color=csil, bgcolor=cno, text_size=size.tiny)
    table.cell(tbl, 1, 2, pctb_str,    text_color=csil, bgcolor=cno, text_size=size.tiny)
    table.cell(tbl, 0, 3, "Setup 15m", text_color=csil, bgcolor=cno, text_size=size.tiny)
    table.cell(tbl, 1, 3, s_rev15,     text_color=csil, bgcolor=s_rev15c, text_size=size.tiny)
    table.cell(tbl, 0, 4, "RSI 5m",    text_color=csil, bgcolor=cno, text_size=size.tiny)
    table.cell(tbl, 1, 4, rsi5m_str,   text_color=csil, bgcolor=cno, text_size=size.tiny)
    table.cell(tbl, 0, 5, "Setup 5m",  text_color=csil, bgcolor=cno, text_size=size.tiny)
    table.cell(tbl, 1, 5, s_rev5m,     text_color=csil, bgcolor=s_rev5mc, text_size=size.tiny)
    table.cell(tbl, 0, 6, "SHORT sinal", text_color=csil, bgcolor=cno, text_size=size.tiny)
    table.cell(tbl, 1, 6, s_short,      text_color=csil, bgcolor=s_shortc, text_size=size.tiny)
    table.cell(tbl, 0, 7, "LONG sinal", text_color=csil, bgcolor=cno, text_size=size.tiny)
    table.cell(tbl, 1, 7, s_long,       text_color=csil, bgcolor=s_longc, text_size=size.tiny)

// ── Alertas ───────────────────────────────────────────────────────────────────
alertcondition(short_confluencia, "SHORT Rev 15M+5M", "SHORT reversao: RSI overbought 15M e 5M + acima BB — AUC 0.65")
alertcondition(short_rev15_forte, "SHORT Rev 15M",    "SHORT reversao: RSI overbought + acima BB 15M")
alertcondition(long_sem_5m_down,  "LONG Rev 15M",     "LONG reversao: RSI oversold + abaixo BB 15M (sem momentum down em 5M)")
alertcondition(long_rev15_forte,  "LONG Rev 15M simples", "LONG reversao: RSI oversold + abaixo BB 15M")
