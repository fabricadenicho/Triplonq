//@version=5
indicator("CL — Lateral", shorttitle="CL", overlay=true, max_bars_back=500, max_boxes_count=100, max_lines_count=200, max_labels_count=10)

// ── Inputs ────────────────────────────────────────────────────────────────────
i_cl   = input.symbol("CL1!", "Símbolo CL")
i_w1h  = input.int(6,   "Largura 1H (barras)", minval=2,  maxval=20, group="Layout")
i_w4h  = input.int(10,  "Largura 4H (barras)", minval=4,  maxval=30, group="Layout")
i_gap  = input.int(3,   "Gap da borda",        minval=0,  maxval=30, group="Layout")
i_sp   = input.int(5,   "Espaço 1H → 4H",     minval=1,  maxval=20, group="Layout")
i_norm = input.int(200, "SMA âncora escala",   minval=20,             group="Escala")

// ── Normalização: MNQ_SMA200 / CL_SMA200 ─────────────────────────────────────
cl_ref  = request.security(i_cl, timeframe.period, close)
cl_sma  = ta.sma(cl_ref, i_norm)
mnq_sma = ta.sma(close,  i_norm)
r = cl_sma > 0 and not na(cl_sma) ? mnq_sma / cl_sma : 1.0

// ── CL 1H — 5 barras ─────────────────────────────────────────────────────────
o1_0=request.security(i_cl,"60",open);   h1_0=request.security(i_cl,"60",high);   l1_0=request.security(i_cl,"60",low);   c1_0=request.security(i_cl,"60",close)
o1_1=request.security(i_cl,"60",open[1]);h1_1=request.security(i_cl,"60",high[1]);l1_1=request.security(i_cl,"60",low[1]);c1_1=request.security(i_cl,"60",close[1])
o1_2=request.security(i_cl,"60",open[2]);h1_2=request.security(i_cl,"60",high[2]);l1_2=request.security(i_cl,"60",low[2]);c1_2=request.security(i_cl,"60",close[2])
o1_3=request.security(i_cl,"60",open[3]);h1_3=request.security(i_cl,"60",high[3]);l1_3=request.security(i_cl,"60",low[3]);c1_3=request.security(i_cl,"60",close[3])
o1_4=request.security(i_cl,"60",open[4]);h1_4=request.security(i_cl,"60",high[4]);l1_4=request.security(i_cl,"60",low[4]);c1_4=request.security(i_cl,"60",close[4])

// ── CL 4H — 3 barras ─────────────────────────────────────────────────────────
o4_0=request.security(i_cl,"240",open);   h4_0=request.security(i_cl,"240",high);   l4_0=request.security(i_cl,"240",low);   c4_0=request.security(i_cl,"240",close)
o4_1=request.security(i_cl,"240",open[1]);h4_1=request.security(i_cl,"240",high[1]);l4_1=request.security(i_cl,"240",low[1]);c4_1=request.security(i_cl,"240",close[1])
o4_2=request.security(i_cl,"240",open[2]);h4_2=request.security(i_cl,"240",high[2]);l4_2=request.security(i_cl,"240",low[2]);c4_2=request.security(i_cl,"240",close[2])

// ── Cores ─────────────────────────────────────────────────────────────────────
C1B = color.new(#26a69a, 0)
C1R = color.new(#ef5350, 0)
C4B = color.new(#00e676, 0)
C4R = color.new(#ff6b6b, 0)

// ── Objetos ───────────────────────────────────────────────────────────────────
var box[]   BXS = array.new_box(0)
var line[]  LNS = array.new_line(0)
var label[] LBS = array.new_label(0)

// ── Função: desenha 1 candle com box + 2 wicks ────────────────────────────────
mkCdl(x1, x2, op, hi, lo, cv, cb, cr) =>
    bull = cv >= op
    fc   = bull ? cb : cr
    wc   = color.new(bull ? cb : cr, 55)
    mid  = math.round((x1 + x2) / 2)
    bt   = math.max(op, cv)
    bb   = math.min(op, cv)
    array.push(BXS, box.new(x1, bt, x2, bb, border_color=fc, bgcolor=fc, xloc=xloc.bar_index))
    array.push(LNS, line.new(mid, hi, mid, bt, color=wc, xloc=xloc.bar_index))
    array.push(LNS, line.new(mid, bb, mid, lo, color=wc, xloc=xloc.bar_index))

// ── Desenha apenas na última barra ────────────────────────────────────────────
if barstate.islast
    for bx in BXS
        box.delete(bx)
    array.clear(BXS)
    for ln in LNS
        line.delete(ln)
    array.clear(LNS)
    for lb in LBS
        label.delete(lb)
    array.clear(LBS)

    bi  = bar_index
    s1  = i_w1h + 1
    s4  = i_w4h + 1
    w1  = i_w1h
    w4  = i_w4h
    x1s = bi + i_gap
    x4s = bi + i_gap + 5 * s1 + i_sp

    // ── 1H — 5 candles (4=mais antigo, 0=mais recente) ────────────────────────
    mkCdl(x1s,          x1s+w1,          o1_4*r, h1_4*r, l1_4*r, c1_4*r, C1B, C1R)
    mkCdl(x1s+s1,       x1s+s1+w1,       o1_3*r, h1_3*r, l1_3*r, c1_3*r, C1B, C1R)
    mkCdl(x1s+2*s1,     x1s+2*s1+w1,     o1_2*r, h1_2*r, l1_2*r, c1_2*r, C1B, C1R)
    mkCdl(x1s+3*s1,     x1s+3*s1+w1,     o1_1*r, h1_1*r, l1_1*r, c1_1*r, C1B, C1R)
    mkCdl(x1s+4*s1,     x1s+4*s1+w1,     o1_0*r, h1_0*r, l1_0*r, c1_0*r, C1B, C1R)

    // ── 4H — 3 candles ────────────────────────────────────────────────────────
    mkCdl(x4s,          x4s+w4,          o4_2*r, h4_2*r, l4_2*r, c4_2*r, C4B, C4R)
    mkCdl(x4s+s4,       x4s+s4+w4,       o4_1*r, h4_1*r, l4_1*r, c4_1*r, C4B, C4R)
    mkCdl(x4s+2*s4,     x4s+2*s4+w4,     o4_0*r, h4_0*r, l4_0*r, c4_0*r, C4B, C4R)

    // ── Labels ────────────────────────────────────────────────────────────────
    m1 = math.max(h1_0*r, h1_1*r, h1_2*r, h1_3*r, h1_4*r)
    m4 = math.max(h4_0*r, h4_1*r, h4_2*r)
    array.push(LBS, label.new(x1s+2*s1, m1*1.001, "CL  1H", style=label.style_none, textcolor=C1B, size=size.small, xloc=xloc.bar_index))
    array.push(LBS, label.new(x4s+s4,   m4*1.001, "CL  4H", style=label.style_none, textcolor=C4B, size=size.small, xloc=xloc.bar_index))
