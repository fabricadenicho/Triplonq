//@version=5
indicator("CL — 1H & 4H Overlay", shorttitle="CL Overlay", overlay=true, max_bars_back=500)

// ── Inputs ────────────────────────────────────────────────────────────────────
i_cl    = input.symbol("CL1!", "Símbolo CL")
i_norm  = input.int(200, "SMA âncora (escala)", minval=20)
i_rsi   = input.int(14,  "RSI Período",         minval=2)
i_show1 = input.bool(true, "Mostrar CL 1H", group="Candles")
i_show4 = input.bool(true, "Mostrar CL 4H", group="Candles")

// ── Normalização: SMA200_MNQ / SMA200_CL ─────────────────────────────────────
cl_c_tf = request.security(i_cl, timeframe.period, close)
cl_sma  = ta.sma(cl_c_tf, i_norm)
mnq_sma = ta.sma(close,   i_norm)
r       = cl_sma > 0 and not na(cl_sma) ? mnq_sma / cl_sma : 1.0

// ── CL 1H ─────────────────────────────────────────────────────────────────────
cl_o1 = request.security(i_cl, "60", open)  * r
cl_h1 = request.security(i_cl, "60", high)  * r
cl_l1 = request.security(i_cl, "60", low)   * r
cl_c1 = request.security(i_cl, "60", close) * r

// ── CL 4H ─────────────────────────────────────────────────────────────────────
cl_o4 = request.security(i_cl, "240", open)  * r
cl_h4 = request.security(i_cl, "240", high)  * r
cl_l4 = request.security(i_cl, "240", low)   * r
cl_c4 = request.security(i_cl, "240", close) * r

// ── Cores ─────────────────────────────────────────────────────────────────────
bull1 = cl_c1 >= cl_o1
bc1   = bull1 ? color.new(#26a69a, 10) : color.new(#ef5350, 10)
wc1   = bull1 ? color.new(#26a69a, 50) : color.new(#ef5350, 50)

bull4 = cl_c4 >= cl_o4
bc4   = bull4 ? color.new(#00e676, 5)  : color.new(#ff1744, 5)
wc4   = bull4 ? color.new(#00e676, 50) : color.new(#ff1744, 50)

// ── Plotcandle ────────────────────────────────────────────────────────────────
plotcandle(i_show1 ? cl_o1 : na, i_show1 ? cl_h1 : na, i_show1 ? cl_l1 : na, i_show1 ? cl_c1 : na, title="CL 1H", color=bc1, wickcolor=wc1, bordercolor=bc1)
plotcandle(i_show4 ? cl_o4 : na, i_show4 ? cl_h4 : na, i_show4 ? cl_l4 : na, i_show4 ? cl_c4 : na, title="CL 4H", color=bc4, wickcolor=wc4, bordercolor=bc4)

// ── Tabela: preço real CL + RSI ───────────────────────────────────────────────
rsi_v = ta.rsi(cl_c_tf, i_rsi)

var table t = table.new(position.top_right, 2, 3, bgcolor=color.new(color.black, 68), border_color=color.new(color.gray, 65), border_width=1)

if barstate.islast
    csil  = color.new(color.silver, 0)
    cbg   = color.new(color.black,  65)
    chdr  = color.new(color.navy,   40)
    rsi_c = rsi_v >= 70 ? color.new(color.red, 0) : rsi_v <= 30 ? color.new(color.lime, 0) : csil
    chg   = nz(cl_c_tf[1]) != 0.0 ? (cl_c_tf - cl_c_tf[1]) / cl_c_tf[1] * 100 : 0.0
    chg_c = chg >= 0.0 ? color.new(#26a69a, 0) : color.new(color.red, 0)
    table.cell(t, 0, 0, "CL",     text_color=color.new(#26a69a, 0), bgcolor=chdr, text_size=size.tiny)
    table.cell(t, 1, 0, str.tostring(cl_c_tf, "#.00") + " (" + str.tostring(chg, "+#.##;-#.##") + "%)", text_color=chg_c, bgcolor=chdr, text_size=size.tiny)
    table.cell(t, 0, 1, "RSI",    text_color=csil, bgcolor=cbg, text_size=size.tiny)
    table.cell(t, 1, 1, str.tostring(rsi_v, "#.#"), text_color=rsi_c, bgcolor=cbg, text_size=size.tiny)
    table.cell(t, 0, 2, "Escala", text_color=csil, bgcolor=cbg, text_size=size.tiny)
    table.cell(t, 1, 2, "x" + str.tostring(r, "#.0"), text_color=color.new(color.gray, 30), bgcolor=cbg, text_size=size.tiny)

// ── Alertas ───────────────────────────────────────────────────────────────────
alertcondition(ta.crossover(rsi_v,  70.0), title="CL RSI OB", message="CL RSI acima de 70")
alertcondition(ta.crossunder(rsi_v, 30.0), title="CL RSI OS", message="CL RSI abaixo de 30")
