//@version=5
indicator("CL — Overlay MNQ", shorttitle="CL Overlay", overlay=true, max_bars_back=500)

// ── Inputs ────────────────────────────────────────────────────────────────────
i_cl   = input.symbol("CL1!", "Símbolo CL")
i_tf   = input.timeframe("",  "Timeframe CL (vazio = mesmo do gráfico)")
i_norm = input.int(200, "MA âncora escala", minval=20,  group="Escala")
i_rsi  = input.int(14,  "RSI Período",      minval=2,   group="RSI")
i_show_ma = input.bool(true, "Mostrar MAs do CL", group="Médias")
i_ma1  = input.int(9,  "MA Rápida", minval=1, group="Médias")
i_ma2  = input.int(21, "MA Lenta",  minval=1, group="Médias")

// ── Dados brutos do CL ───────────────────────────────────────────────────────
cl_o = request.security(i_cl, i_tf, open,  lookahead=barmerge.lookahead_off)
cl_h = request.security(i_cl, i_tf, high,  lookahead=barmerge.lookahead_off)
cl_l = request.security(i_cl, i_tf, low,   lookahead=barmerge.lookahead_off)
cl_c = request.security(i_cl, i_tf, close, lookahead=barmerge.lookahead_off)

// ── Normalização: escala CL → MNQ via SMA200 ─────────────────────────────────
// ratio = SMA200_MNQ / SMA200_CL  →  CL * ratio fica na faixa de preço do MNQ
cl_sma  = ta.sma(cl_c, i_norm)
mnq_sma = ta.sma(close, i_norm)
ratio   = cl_sma != 0 and not na(cl_sma) ? mnq_sma / cl_sma : 1.0

n_o = cl_o * ratio
n_h = cl_h * ratio
n_l = cl_l * ratio
n_c = cl_c * ratio

// ── Candles CL normalizados ───────────────────────────────────────────────────
bc = n_c >= n_o ? color.new(color.teal, 10) : color.new(color.red, 10)
wc = n_c >= n_o ? color.new(color.teal, 50) : color.new(color.red, 50)
plotcandle(n_o, n_h, n_l, n_c, title="CL norm", color=bc, wickcolor=wc, bordercolor=bc)

// ── MAs do CL (normalizadas) ──────────────────────────────────────────────────
ma1n = ta.sma(cl_c, i_ma1) * ratio
ma2n = ta.sma(cl_c, i_ma2) * ratio
plot(i_show_ma ? ma1n : na, "CL MA Rápida", color=color.new(color.yellow, 20), linewidth=1)
plot(i_show_ma ? ma2n : na, "CL MA Lenta",  color=color.new(color.orange, 20), linewidth=2)

// ── RSI do CL (valor real, exibido na tabela) ─────────────────────────────────
rsi_v = ta.rsi(cl_c, i_rsi)

// ── Tabela: preço real CL + RSI ───────────────────────────────────────────────
var table t = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 68), border_color=color.new(color.gray, 65), border_width=1)

if barstate.islast
    csil  = color.new(color.silver, 0)
    cbg   = color.new(color.black,  65)
    chdr  = color.new(color.navy,   40)
    rsi_c = rsi_v >= 70 ? color.new(color.red, 0) : rsi_v <= 30 ? color.new(color.lime, 0) : csil
    chg   = nz(cl_c[1]) != 0.0 ? (cl_c - cl_c[1]) / cl_c[1] * 100 : 0.0
    chg_c = chg >= 0.0 ? color.new(color.teal, 0) : color.new(color.red, 0)

    table.cell(t, 0, 0, "CL",      text_color=color.new(color.teal, 0), bgcolor=chdr, text_size=size.tiny)
    table.cell(t, 1, 0, i_tf == "" ? str.tostring(timeframe.period) : i_tf, text_color=csil, bgcolor=chdr, text_size=size.tiny)

    table.cell(t, 0, 1, "Preço",   text_color=csil, bgcolor=cbg, text_size=size.tiny)
    table.cell(t, 1, 1, str.tostring(cl_c, "#.00") + " (" + str.tostring(chg, "+#.##;-#.##") + "%)", text_color=chg_c, bgcolor=cbg, text_size=size.tiny)

    table.cell(t, 0, 2, "RSI",     text_color=csil, bgcolor=cbg, text_size=size.tiny)
    table.cell(t, 1, 2, str.tostring(rsi_v, "#.#"), text_color=rsi_c, bgcolor=cbg, text_size=size.tiny)

    table.cell(t, 0, 3, "Escala",  text_color=csil, bgcolor=cbg, text_size=size.tiny)
    table.cell(t, 1, 3, "x" + str.tostring(ratio, "#.0"), text_color=color.new(color.gray, 30), bgcolor=cbg, text_size=size.tiny)

// ── Alertas RSI CL ────────────────────────────────────────────────────────────
alertcondition(ta.crossover(rsi_v,  70.0), title="CL RSI OB", message="CL RSI acima de 70 — divergência BEAR vs MNQ possível")
alertcondition(ta.crossunder(rsi_v, 30.0), title="CL RSI OS", message="CL RSI abaixo de 30 — divergência BULL vs MNQ possível")
