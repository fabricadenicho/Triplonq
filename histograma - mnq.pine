//@version=5
indicator("Histograma ML · MNQ", shorttitle="HIST·MNQ", overlay=false)

// INPUTS
hist_mode  = input.string("di_spread", "Modo", options=["di_spread", "vol_spread_mnq_cl", "bb_width", "dist_sma50", "price_div_cl", "dist_pdh", "dist_pmh", "vol_pct"], group="Histograma")
scale_div  = input.int(10000, "Scale price_div_cl x", minval=100, group="Histograma")
sym_cl     = input.symbol("CL1!",    "CL",  group="Simbolos")
sym_btc    = input.symbol("BTCUSDT", "BTC", group="Simbolos")
adx_len    = input.int(17,   "ADX Length",    minval=1, group="Parametros")
adx_thr    = input.float(14, "ADX Threshold", minval=1, group="Parametros")
rsi_len    = input.int(21,   "RSI Length",    minval=1, group="Parametros")
bb_len     = input.int(20,   "BB Length",     minval=1, group="Parametros")
vol_len    = input.int(20,   "Vol Length",    minval=1, group="Parametros")
col_pos    = input.color(color.new(#2de39a, 35), "Positivo",    group="Visual")
col_neg    = input.color(color.new(#ff6b6b, 25), "Negativo",    group="Visual")
col_signal = input.color(color.new(#ffd166,  0), "Sinal ativo", group="Visual")
show_panel = input.bool(true, "Painel de checks", group="Visual")

// DADOS EXTERNOS
cl_c      = request.security(sym_cl,  timeframe.period, close, gaps=barmerge.gaps_off)
btc_c     = request.security(sym_btc, timeframe.period, close, gaps=barmerge.gaps_off)
cl_sma50  = request.security(sym_cl,  timeframe.period, ta.sma(close, 50))
btc_sma50 = request.security(sym_btc, timeframe.period, ta.sma(close, 50))
btc_ema20 = request.security(sym_btc, timeframe.period, ta.ema(close, 20))

// KEY LEVELS
pdh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
pdl = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_on)
pwh = request.security(syminfo.tickerid, "W", high[1], lookahead=barmerge.lookahead_on)
pwl = request.security(syminfo.tickerid, "W", low[1],  lookahead=barmerge.lookahead_on)
pmh = request.security(syminfo.tickerid, "M", high[1], lookahead=barmerge.lookahead_on)
pml = request.security(syminfo.tickerid, "M", low[1],  lookahead=barmerge.lookahead_on)

// INDICADORES
[di_plus, di_minus, adx_val] = ta.dmi(adx_len, adx_len)
rsi_val = ta.rsi(close, rsi_len)
sma50   = ta.sma(close, 50)
ema20   = ta.ema(close, 20)
[_, bb_up, bb_dn] = ta.bb(close, bb_len, 2)
bb_w    = (bb_up - bb_dn) / ta.sma(close, bb_len) * 100

ret_mnq = close[1] != 0 ? (close - close[1]) / close[1] : 0.0
ret_cl  = cl_c[1]  != 0 ? (cl_c  - cl_c[1])  / cl_c[1]  : 0.0
vol_mnq = ta.stdev(ret_mnq, vol_len) * 100
vol_cl  = ta.stdev(ret_cl,  vol_len) * 100

price_div_cl  = ret_mnq * ret_cl
di_spread_val = di_plus - di_minus
dist_sma50_v  = (close - sma50) / sma50 * 100
vol_spread_v  = vol_mnq - vol_cl

dist_pdh_v  = pdh != 0 ? (close - pdh) / pdh * 100 : 0.0
dist_pdl_v  = pdl != 0 ? (close - pdl) / pdl * 100 : 0.0
dist_pmh_v  = pmh != 0 ? (close - pmh) / pmh * 100 : 0.0
dist_pml_v  = pml != 0 ? (close - pml) / pml * 100 : 0.0
above_pdh   = close > pdh
above_pmh   = close > pmh
prev_day_range_pct = pdl != 0 ? (pdh - pdl) / pdl * 100 : 0.0

ema20_bias  = (close > ema20 ? 1 : 0) + (btc_c > btc_ema20 ? 1 : 0)
sma50_align = (close > sma50 ? 1 : 0) + (cl_c > cl_sma50 ? 1 : 0) + (btc_c > btc_sma50 ? 1 : 0)

h          = hour(time, "UTC")
in_us      = h >= 13 and h < 21
in_asia    = h >= 0  and h < 8
in_london  = h >= 8  and h < 15
in_ny      = h >= 13 and h < 20
in_overlap = in_london and in_ny

diverging  = price_div_cl < 0
strong_div = diverging and adx_val > adx_thr
us_prime   = strong_div and in_us

// HISTOGRAMA
hist_val = switch hist_mode
    "di_spread"         => di_spread_val
    "vol_spread_mnq_cl" => vol_spread_v * 1000
    "bb_width"          => bb_w
    "dist_sma50"        => dist_sma50_v
    "price_div_cl"      => price_div_cl * scale_div
    "dist_pdh"          => dist_pdh_v
    "dist_pmh"          => dist_pmh_v
    "vol_pct"           => vol_mnq
    =>                     di_spread_val

cor = strong_div ? col_signal : hist_val > 0 ? col_pos : col_neg
if hist_mode == "vol_pct"
    cor := vol_mnq < 0.334 ? color.new(#2de39a, 35) : vol_mnq < 0.6 ? color.new(#ffd166, 40) : color.new(#ff6b6b, 25)

plot(hist_val, "Histograma", style=plot.style_histogram, color=cor, linewidth=2)
hline(0, "Zero", color=color.new(color.gray, 50), linestyle=hline.style_dashed)
plot(ta.ema(hist_val, 5), "EMA5", color=color.new(color.white, 60), linewidth=1)
plotshape(strong_div and not us_prime, "strong_div", shape.triangleup, location.bottom, color=color.new(col_signal, 0), size=size.tiny)
plotshape(us_prime, "US_PRIME", shape.diamond, location.bottom, color=color.new(#2de39a, 0), size=size.small)
plotshape(above_pdh and not above_pdh[1], "PDH Break", shape.triangleup, location.top, color=color.new(#62b0ff, 20), size=size.tiny)
plotshape(above_pmh and not above_pmh[1], "PMH Break", shape.diamond, location.top, color=color.new(#2de39a, 0), size=size.small)
bgcolor(strong_div ? color.new(col_signal, 92) : na, title="Strong Div BG")

// PAINEL
C_BG   = color.new(#071018, 5)
C_BG2  = color.new(#0e1823, 0)
C_LINE = color.new(#1f3246, 100)
C_MUT  = color.new(#6f8298, 0)
C_WHT  = color.new(#edf5ff, 0)
C_GRN  = color.new(#2de39a, 0)
C_RED  = color.new(#ff6b6b, 0)
C_YEL  = color.new(#ffd166, 0)
C_BLU  = color.new(#62b0ff, 0)

chk(c) => c ? "+" : "-"

var table t = table.new(position.top_right, 2, 18, bgcolor=C_BG, border_width=1, border_color=C_LINE, frame_width=1, frame_color=color.new(#2a4663, 100))

if barstate.islast and show_panel
    in_pf   = h >= 8 and h < 20
    kz_str  = in_overlap ? "OVERLAP" : in_ny ? "NEW YORK" : in_london ? "LONDON" : in_asia ? "ASIA" : "FORA"
    kz_col  = in_overlap ? color.new(#c77dff, 0) : in_ny ? C_GRN : in_london ? C_BLU : C_MUT
    sig_lng = strong_div and di_spread_val > 0 and in_pf
    sig_sht = strong_div and di_spread_val <= 0 and in_pf
    dec_str = sig_lng ? "COMPRAR MNQ" : sig_sht ? "VENDER MNQ" : strong_div ? "strong_div" : "AGUARDAR"
    dec_col = sig_lng ? C_GRN : sig_sht ? C_RED : strong_div ? C_YEL : C_MUT
    adx_ok  = adx_val > adx_thr
    rsi_c   = rsi_val >= 65 ? C_RED : rsi_val <= 35 ? C_GRN : C_YEL
    di_ok   = di_spread_val > 0
    vs_ok   = vol_spread_v > 0
    ema_ok  = ema20_bias >= 1
    n       = (adx_ok ? 1 : 0) + (diverging ? 1 : 0) + (in_us ? 1 : 0) + (ema_ok ? 1 : 0)
    n_col   = n >= 4 ? C_GRN : n == 3 ? C_YEL : n == 2 ? color.new(#ff8c00, 0) : C_RED
    ema_str = ema20_bias == 2 ? "acima 58%L" : ema20_bias == 1 ? "misto 59%L" : "abaixo 45%L"
    ema_col = ema20_bias == 2 ? C_GRN : ema20_bias == 1 ? C_YEL : C_RED
    al_str  = sma50_align == 3 ? "3 forte" : sma50_align == 2 ? "2 mod" : sma50_align == 1 ? "1 fraco" : "0 bear"
    al_col  = sma50_align >= 2 ? C_GRN : sma50_align == 1 ? C_YEL : C_RED
    sess_t  = in_us ? "+ US " + str.tostring(h) + "h" : "- FORA " + str.tostring(h) + "h UTC"
    chk_t   = chk(adx_ok) + " ADX  " + chk(diverging) + " div  " + chk(in_us) + " US  " + chk(ema_ok) + " EMA"
    table.cell(t, 0, 0, "MNQ — " + hist_mode, text_color=C_MUT, bgcolor=C_BG2, text_size=size.tiny, text_halign=text.align_left)
    table.cell(t, 1, 0, dec_str, text_color=dec_col, bgcolor=C_BG2, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 0, 1, "ADX", text_color=C_MUT, bgcolor=C_BG, text_size=size.tiny)
    table.cell(t, 1, 1, str.tostring(adx_val, "#.#") + (adx_ok ? " +" : ""), text_color=adx_val >= 25 ? color.new(#c77dff, 0) : adx_val >= 17 ? C_BLU : adx_ok ? C_YEL : C_MUT, bgcolor=C_BG, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 0, 2, "RSI 21", text_color=C_MUT, bgcolor=C_BG, text_size=size.tiny)
    table.cell(t, 1, 2, str.tostring(rsi_val, "#.#"), text_color=rsi_c, bgcolor=C_BG, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 0, 3, "DI Spread", text_color=C_MUT, bgcolor=C_BG, text_size=size.tiny)
    table.cell(t, 1, 3, str.tostring(di_spread_val, "#.#") + " " + chk(di_ok), text_color=di_ok ? C_GRN : C_RED, bgcolor=C_BG, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 0, 4, "DIV CL-MNQ", text_color=C_MUT, bgcolor=C_BG, text_size=size.tiny)
    table.cell(t, 1, 4, str.tostring(price_div_cl * 10000, "#.##") + " " + chk(diverging), text_color=diverging ? C_YEL : C_WHT, bgcolor=C_BG, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 0, 5, "VOL MNQ-CL", text_color=C_MUT, bgcolor=C_BG, text_size=size.tiny)
    table.cell(t, 1, 5, str.tostring(vol_spread_v, "#.###"), text_color=vs_ok ? C_GRN : C_RED, bgcolor=C_BG, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 0, 6, "SESSAO", text_color=C_MUT, bgcolor=C_BG, text_size=size.tiny)
    table.cell(t, 1, 6, sess_t, text_color=in_us ? C_GRN : C_MUT, bgcolor=C_BG, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 0, 7, "KILL ZONE", text_color=C_MUT, bgcolor=C_BG, text_size=size.tiny)
    table.cell(t, 1, 7, kz_str, text_color=kz_col, bgcolor=C_BG, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 0, 8, "REGIME EMA20", text_color=C_MUT, bgcolor=C_BG, text_size=size.tiny)
    table.cell(t, 1, 8, ema_str, text_color=ema_col, bgcolor=C_BG, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 0, 9, "SMA50 ALIGN", text_color=C_MUT, bgcolor=C_BG, text_size=size.tiny)
    table.cell(t, 1, 9, al_str, text_color=al_col, bgcolor=C_BG, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 0, 10, "DIST SMA50", text_color=C_MUT, bgcolor=C_BG, text_size=size.tiny)
    table.cell(t, 1, 10, str.tostring(dist_sma50_v, "#.##") + "%", text_color=dist_sma50_v > 0 ? C_GRN : C_RED, bgcolor=C_BG, text_size=size.small, text_halign=text.align_right)
    pdh_s  = (dist_pdh_v >= 0 ? "+" : "") + str.tostring(dist_pdh_v, "#.##") + "%"
    pdl_s  = (dist_pdl_v >= 0 ? "+" : "") + str.tostring(dist_pdl_v, "#.##") + "%"
    pmh_s  = (dist_pmh_v >= 0 ? "+" : "") + str.tostring(dist_pmh_v, "#.##") + "%"
    pml_s  = (dist_pml_v >= 0 ? "+" : "") + str.tostring(dist_pml_v, "#.##") + "%"
    pdh_c  = above_pdh ? C_GRN : dist_pdl_v < 0 ? C_RED : C_YEL
    pmh_c  = above_pmh ? C_GRN : dist_pml_v < 0 ? C_RED : C_MUT
    table.cell(t, 0, 11, "PDH / PDL", text_color=C_MUT, bgcolor=C_BG, text_size=size.tiny)
    table.cell(t, 1, 11, pdh_s + " / " + pdl_s, text_color=pdh_c, bgcolor=C_BG, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 0, 12, "PMH / PML", text_color=C_MUT, bgcolor=C_BG, text_size=size.tiny)
    table.cell(t, 1, 12, pmh_s + " / " + pml_s, text_color=pmh_c, bgcolor=C_BG, text_size=size.tiny, text_halign=text.align_right)
    vol_c  = vol_mnq < 0.334 ? C_GRN : vol_mnq < 0.6 ? C_YEL : C_RED
    vol_s  = str.tostring(vol_mnq, "#.###") + "% " + (vol_mnq < 0.334 ? "baixa ✓" : vol_mnq < 0.6 ? "média" : "ALTA !")
    table.cell(t, 0, 13, "VOL% ML thr<0.334", text_color=C_MUT, bgcolor=C_BG, text_size=size.tiny)
    table.cell(t, 1, 13, vol_s, text_color=vol_c, bgcolor=C_BG, text_size=size.tiny, text_halign=text.align_right)
    rng_c  = prev_day_range_pct < 0.5 ? C_GRN : prev_day_range_pct < 2.0 ? C_YEL : C_RED
    rng_s  = str.tostring(prev_day_range_pct, "#.##") + "% range"
    table.cell(t, 0, 14, "RANGE DIA-1", text_color=C_MUT, bgcolor=C_BG, text_size=size.tiny)
    table.cell(t, 1, 14, rng_s, text_color=rng_c, bgcolor=C_BG, text_size=size.tiny, text_halign=text.align_right)
    pf_v   = in_pf ? "+ JANELA 8-20h" : "- FORA " + str.tostring(h) + "h"
    pf_c   = in_pf ? C_GRN : C_MUT
    table.cell(t, 0, 15, "PF AMBOS 1.5:3R", text_color=C_MUT, bgcolor=C_BG, text_size=size.tiny)
    table.cell(t, 1, 15, pf_v, text_color=pf_c, bgcolor=C_BG, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 0, 16, "CHECKS", text_color=C_MUT, bgcolor=C_LINE, text_size=size.tiny)
    table.cell(t, 1, 16, chk_t, text_color=n_col, bgcolor=C_LINE, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 0, 17, "AUC 0.602 | Acc 43%", text_color=C_MUT, bgcolor=C_BG2, text_size=size.tiny, text_halign=text.align_left)
    table.cell(t, 1, 17, str.tostring(close, "#.##"), text_color=C_WHT, bgcolor=C_BG2, text_size=size.small, text_halign=text.align_right)
